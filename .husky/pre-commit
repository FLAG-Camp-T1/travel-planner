#!/bin/sh

if ! command -v git-lfs >/dev/null 2>&1; then
  echo ""
  echo "========================================================"
  echo "[FATAL ERROR] 您的环境尚未安装 Git LFS！"
  echo "本项目需要 LFS 追踪大文件，缺少 LFS 将导致仓库损坏。"
  echo "请立即终止提交，并前往安装 Git LFS："
  echo "  - Mac: brew install git-lfs"
  echo "  - Windows安装包: https://git-lfs.github.com/"
  echo "安装完成后，请务必执行一次 'git lfs install'。"
  echo "========================================================"
  echo ""
  exit 1
fi

if ! git config filter.lfs.smudge >/dev/null 2>&1; then
  echo "========================================================"
  echo "[FATAL ERROR] Git LFS 已安装，但尚未初始化！"
  echo "您的 Git 尚未配置 LFS 过滤器，直接提交会把大文件本体塞入 Git 历史。"
  echo ""
  echo "👉 请立即在终端执行以下命令进行初始化："
  echo "    git lfs install"
  echo "========================================================"
  exit 1
fi

echo "正在由 lint-staged 检查增量代码格式..."

npx lint-staged || {
  echo ""
  echo "您的提交未通过代码规范检查！"
  echo "========================================================"
  echo "快速修复指南："
  echo ""
  echo "【前端问题】请打开终端进入 frontend 目录，运行："
  echo "    npm run format   (自动修复排版问题)"
  echo "    (若上方有 ESLint 逻辑报错，请手动根据提示修改代码)"
  echo ""
  echo "【后端问题】请打开终端进入 backend 目录，运行："
  echo "    ./gradlew spotlessApply  (自动修复 Java 格式问题)"
  echo "========================================================"
  echo "请修复错误后，再次尝试 commit。"
  echo ""
  exit 1
}

echo "代码已通过规范检查！"